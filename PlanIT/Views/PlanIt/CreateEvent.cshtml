@{
    Layout = "~/Views/Shared/_PlanITLayout.cshtml";
}

<style>
    :root {
        --bg-dark: #0f111a;
        --card-bg: rgba(255, 255, 255, 0.05);
        --accent-gradient: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
        --text-main: #f8fafc;
        --text-muted: #94a3b8;
    }

    body {
        background-color: var(--bg-dark);
        color: var(--text-main);
        font-family: 'Inter', sans-serif;
    }

    /* Standardized Blurred Navbar */
    nav {
        background: rgba(15, 17, 26, 0.8) !important;
        backdrop-filter: blur(10px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: none;
    }

    /* Input Styling to match Dark Theme */
    input.white-text, textarea.white-text {
        border-bottom: 1px solid rgba(255, 255, 255, 0.1) !important;
        box-shadow: none !important;
    }

        input.white-text:focus, textarea.white-text:focus {
            border-bottom: 1px solid #6366f1 !important;
        }

    /* Fixed label behavior for dark theme */
    .input-field label {
        color: var(--text-muted) !important;
    }

    .input-field input:focus + label {
        color: #6366f1 !important;
    }

    .event-editor-card {
        background: var(--card-bg);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 24px;
        padding: 40px;
        margin-top: 30px;
    }

    .editor-sidebar {
        padding-right: 40px;
    }

    .status-badge {
        background: rgba(0, 230, 118, 0.1);
        border: 1px solid rgba(0, 230, 118, 0.2);
        padding: 12px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        color: #00e676;
        font-size: 0.85rem;
    }
</style>

<div ng-controller="PlanITController">
    <nav>
        <div class="nav-wrapper">
            <a href="#" class="brand-logo" style="margin-left:30px; font-weight: 800; letter-spacing: -1px;">PLAN<span style="color:#6366f1">IT</span></a>
            <ul class="right hide-on-med-and-down" style="margin-right:30px;">
                <li><a href="#" ng-click="RedirectingPage(404)">Dashboard</a></li>
                <li class="active"><a href="#" style="color:#6366f1">Events</a></li>
                <li><a href="#" ng-click="RedirectingPage(808)">Users</a></li>
                <li><a href="#" class="btn-flat" style="color: #ff4757; border: 1px solid #ff4757; border-radius: 10px; line-height: 36px; margin-left: 15px;" ng-click="RedirectingPage(101)">Log Out</a></li>
            </ul>
        </div>
    </nav>

    <div class="container" style="width: 90%; max-width: 1400px; margin-top: 50px;">
        <div class="row">

            <div class="col s12 l4 editor-sidebar">
                <h4 style="font-weight: 800; margin-bottom: 10px;">Event Studio</h4>
                <p style="color: var(--text-muted); line-height: 1.6;">
                    Fill out the details to launch your next experience. All fields saved here will be published immediately to the event catalog.
                </p>

                <div style="margin-top: 30px;">
                    <div class="status-badge">
                        <i class="material-icons" style="margin-right: 10px;">lens</i>
                        <span>System: Draft Mode Active</span>
                    </div>
                </div>
            </div>

            <div class="col s12 l8">
                <div class="event-editor-card">
                    <div class="row" style="margin-bottom: 0;">

                        <div class="input-field col s12">
                            <label for="event_title">Event Title</label>
                            <input id="event_title" type="text" ng-model="event.Title" class="white-text" style="font-size: 1.8rem; font-weight: 700;">
                        </div>

                        <div class="input-field col s12 m6">
                            <i class="material-icons prefix">calendar_today</i>
                            <input id="event_date" type="date" ng-model="event.EventDate" class="white-text">
                            <label for="event_date" class="active">Schedule Date</label>
                        </div>

                        <div class="input-field col s12 m6">
                            <i class="material-icons prefix">place</i>
                            <input id="location" type="text" ng-model="event.Location" class="white-text">
                            <label for="location">Venue / Location</label>
                        </div>

                        <div class="input-field col s12 m6">
                            <i class="material-icons prefix">payments</i>
                            <input id="price" type="number" step="0.01" ng-model="event.Price" class="white-text">
                            <label for="price">Ticket Price (₱)</label>
                        </div>

                        <div class="input-field col s12 m6">
                            <i class="material-icons prefix">confirmation_number</i>
                            <input id="tickets" type="number" ng-model="event.TotalTickets" class="white-text">
                            <label for="tickets">Total Ticket Inventory</label>
                        </div>

                        <div class="input-field col s12">
                            <i class="material-icons prefix">short_text</i>
                            <textarea id="description" class="materialize-textarea white-text" ng-model="event.Description" style="min-height: 100px;"></textarea>
                            <label for="description">Public Description</label>
                        </div>
                    </div>

                    <div class="row" style="margin-top: 30px; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 30px; margin-bottom: 0;">
                        <div class="col s12 right-align">
                            <button class="btn-flat grey-text" style="margin-right: 15px; text-transform: none; font-weight: 600;" ng-click="RedirectingPage(404)">
                                Discard Draft
                            </button>
                            <button class="btn-large"
                                    style="background: var(--accent-gradient); border-radius: 12px; font-weight: 700; text-transform: uppercase; padding: 0 40px;"
                                    ng-click="createEvent()">
                                Publish Event
                            </button>
                        </div>
                    </div>
                </div>

                <p class="center-align" style="margin-top: 30px; color: var(--text-muted); font-size: 0.75rem; letter-spacing: 2px; text-transform: uppercase;">
                    Powered by PlanIT Studio &copy; 2026
                </p>
            </div>
        </div>
    </div>
</div>