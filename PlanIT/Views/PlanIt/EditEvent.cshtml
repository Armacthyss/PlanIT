@{
    Layout = "~/Views/Shared/_PlanITLayout.cshtml";
}

<style>
    :root {
        --bg-dark: #0f111a;
        --card-bg: rgba(255, 255, 255, 0.05);
        --accent-gradient: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
        --text-main: #f8fafc;
        --text-muted: #94a3b8;
        --input-focus: #6366f1;
    }

    body {
        background-color: var(--bg-dark);
        color: var(--text-main);
        font-family: 'Inter', sans-serif;
    }

    /* Standardized Blurred Navbar */
    nav {
        background: rgba(15, 17, 26, 0.8) !important;
        backdrop-filter: blur(10px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: none;
    }

    /* Table Design */
    .custom-table {
        background: var(--card-bg);
        border-radius: 20px;
        border-collapse: separate;
        border-spacing: 0;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

        .custom-table thead {
            background: rgba(255, 255, 255, 0.03);
        }

        .custom-table th {
            color: var(--text-muted);
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 1px;
            padding: 20px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .custom-table td {
            padding: 15px 20px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            color: var(--text-main);
        }

        .custom-table tbody tr:hover {
            background: rgba(99, 102, 241, 0.05) !important;
            transition: 0.3s;
        }

    /* Glass Edit Card */
    .edit-card {
        background: var(--card-bg);
        border: 1px solid rgba(99, 102, 241, 0.3);
        border-radius: 25px;
        padding: 40px;
        margin-top: 40px;
        backdrop-filter: blur(10px);
        animation: fadeIn 0.4s ease-out;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .input-field input, .input-field textarea {
        color: white !important;
        border-bottom: 1px solid rgba(255, 255, 255, 0.2) !important;
    }

        .input-field input:focus, .input-field textarea:focus {
            border-bottom: 1px solid var(--input-focus) !important;
            box-shadow: 0 1px 0 0 var(--input-focus) !important;
        }

    .btn-edit-action {
        background: var(--accent-gradient);
        border-radius: 8px;
        text-transform: none;
        font-weight: 700;
        transition: 0.3s;
    }

        .btn-edit-action:hover {
            box-shadow: 0 5px 15px rgba(99, 102, 241, 0.4);
        }
</style>

<div ng-controller="PlanITController" ng-init="loadEvents()">
    <nav>
        <div class="nav-wrapper">
            <a href="#" class="brand-logo" style="margin-left:30px; font-weight: 800; letter-spacing: -1px;">PLAN<span style="color:#6366f1">IT</span></a>
            <ul class="right hide-on-med-and-down" style="margin-right:30px;">
                <li><a href="#" ng-click="RedirectingPage(404)">Dashboard</a></li>
                <li class="active"><a href="#" style="color:#6366f1">Manage Events</a></li>
                <li><a href="#" ng-click="RedirectingPage(808)">Users</a></li>
                <li><a href="#" class="btn-flat" style="color: #ff4757; border: 1px solid #ff4757; border-radius: 10px; line-height: 36px; margin-left: 15px;" ng-click="RedirectingPage(101)">Log Out</a></li>
            </ul>
        </div>
    </nav>

    <div class="container" style="width: 95%; max-width: 1400px; margin-top: 50px; margin-bottom: 100px;">
        <div class="row">
            <div class="col s12">
                <h4 style="font-weight: 800; letter-spacing: -1px;">Event <span style="color:#6366f1">Configuration</span></h4>
                <p style="color: var(--text-muted); margin-bottom: 40px;">Select an entry from the live database to modify its parameters.</p>
            </div>

            <div class="col s12">
                <table class="custom-table highlight centered">
                    <thead>
                        <tr>
                            <th>Event Name</th>
                            <th>Schedule</th>
                            <th>Location</th>
                            <th>Price</th>
                            <th>Available Slots</th>
                            <th>Operations</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr ng-repeat="event in events">
                            <td style="font-weight: 600;">{{event.Title}}</td>
                            <td>{{event.EventDate | date:'MMM d, yyyy'}}</td>
                            <td><span class="grey-text">{{event.Location}}</span></td>
                            <td style="color: #2ed573; font-weight: 700;">{{event.Price | currency : '₱'}}</td>
                            <td>{{event.TotalTickets}}</td>
                            <td>
                                <button class="btn-small waves-effect waves-light"
                                        style="background: rgba(99, 102, 241, 0.2); color: #6366f1; border-radius: 6px; box-shadow: none; font-weight: 700;"
                                        ng-click="editEvent(event)">
                                    Configure
                                </button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="col s12" ng-show="selectedEvent.Title">
                <div class="edit-card">
                    <div class="row">
                        <div class="col s12">
                            <h5 style="margin-bottom: 30px; font-weight: 700;">
                                Editing: <span class="indigo-text text-accent-2">{{selectedEvent.Title}}</span>
                            </h5>
                        </div>

                        <div class="input-field col s12 m6">
                            <input id="edit_title" type="text" ng-model="selectedEvent.Title">
                            <label for="edit_title" class="active">Event Title</label>
                        </div>

                        <div class="input-field col s12 m6">
                            <input id="edit_date" type="date" ng-model="selectedEvent.EventDate" class="active">
                            <label for="edit_date" class="active">Event Date</label>
                        </div>

                        <div class="input-field col s12 m4">
                            <input id="edit_loc" type="text" ng-model="selectedEvent.Location">
                            <label for="edit_loc" class="active">Location</label>
                        </div>

                        <div class="input-field col s12 m4">
                            <input id="edit_price" type="number" step="0.01" ng-model="selectedEvent.Price">
                            <label for="edit_price" class="active">Price (₱)</label>
                        </div>

                        <div class="input-field col s12 m4">
                            <input id="edit_tickets" type="number" ng-model="selectedEvent.TotalTickets">
                            <label for="edit_tickets" class="active">Tickets</label>
                        </div>

                        <div class="input-field col s12">
                            <textarea id="edit_desc" class="materialize-textarea" ng-model="selectedEvent.Description"></textarea>
                            <label for="edit_desc" class="active">Description</label>
                        </div>

                        <div class="col s12" style="margin-top: 20px;">
                            <button class="btn btn-edit-action waves-effect waves-light" ng-click="updateEvent()">
                                Update Database
                            </button>
                            <button class="btn-flat waves-effect" style="color: #ff4757; font-weight: 600;" ng-click="selectedEvent = {}">
                                Discard Changes
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>